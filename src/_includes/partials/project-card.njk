<article class="project-card">
  <a class="project-link" href="{{ project.url }}">
    <div class="project-text">
      <p class="project-tag">{{ project.data.tag }}</p>
      <h2 class="project-title">{{ project.data.title }}</h2>
      <p class="project-desc">{{ project.data.description }}</p>
    </div>

    <div class="project-media project-media--primary">
      <video
        src="{{ project.data.media.primaryVideo }}"
        autoplay muted loop playsinline preload="metadata"
        aria-label="Primary project video"></video>
    </div>

    <div class="project-media project-media--secondary">
      <img
        src="{{ project.data.media.secondaryImage }}"
        alt="{{ project.data.media.secondaryAlt or project.data.title }}" />
    </div>
  </a>
</article>